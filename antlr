

// Reglas Sintácticas
programa    : 'programa' IDENTIFICADOR '{' instruccion* '}' EOF ;
instruccion : asignacion | excepcion | bloque | imprimir ;
asignacion  : IDENTIFICADOR ':=' expresion ';' ;
excepcion   : 'procesar' bloque 'manejarError' '(' IDENTIFICADOR ')' bloque ';' ;
bloque      : '{' instruccion* '}' ;
imprimir    : 'imprimir' '(' expresion ')' ';' ;

expresion   : termino (('+' | '-') termino)* ;
termino     : NUMERO | IDENTIFICADOR | '(' expresion ')' ;

// Reglas Léxicas (Tokens)
NUMERO        : DIGITO+ ('.' DIGITO+)? ;
IDENTIFICADOR : LETRA (LETRA | DIGITO | '_')* ;

fragment LETRA  : [a-zA-Z] ;
fragment DIGITO : [0-9] ;

// Ignorar espacios, tabulaciones y saltos de línea en el análisis
WS : [ \t\r\n]+ -> skip ;
